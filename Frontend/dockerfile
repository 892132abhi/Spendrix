FROM node:20-slim

WORKDIR /app

# Copy package files first to leverage Docker's installation cache
COPY package.json package-lock.json* /app/
RUN npm install

# Copy the application source code
COPY . /app/

EXPOSE 5173

# Run the dev server and bind it to host 0.0.0.0 so Docker can route traffic
CMD ["npm", "run", "dev", "--", "--host"]